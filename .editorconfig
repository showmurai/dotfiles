# top-most EditorConfig file
root = true

# common setting
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# for makefile
[Makefile]
indent_style = tab
indent_size = 8

# for shell script
[*.sh]
indent_style = space
indent_size = 2

# for go-lang
[*.go]
indent_style = tab
indent_size = 4

# for python
[*.py]
indent_style = space
indent_size = 4

# for javascript / typescript
[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_style = space
indent_size = 2

# for c/c++
[*.{c,cpp,h}]
indent_style = tab
indent_size = 4

# for ruby
[*.rb]
indent_style = space
indent_size = 2

# for yaml / yml
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# for xml
[*.xml]
indent_style = space
indent_size = 2

# for json / toml
[*.{json,toml}]
indent_style = space
indent_size = 2

# for terraform
[*.tf]
indent_style = space
indent_size = 2
